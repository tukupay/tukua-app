  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild:android": "expo prebuild --platform android --clean",
    "build:apk": "npx --yes eas-cli@16.28.0 build --platform android --profile preview",
    "build:aab": "npx --yes eas-cli@16.28.0 build --platform android --profile production",
    "build:aab:ci": "npx --yes eas-cli@16.28.0 build --platform android --profile production --non-interactive",
    "build:apk:ci": "npx --yes eas-cli@16.28.0 build --platform android --profile preview --non-interactive",
    "credentials:android": "npx --yes eas-cli@16.28.0 credentials -p android",
    "build:apk:local": "expo run:android --variant release",
    "doctor": "npx expo-doctor",
    "generate:logos": "python scripts/generate-logos.py"
  },
  "dependencies": {
